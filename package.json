{
  "name": "@velocity-bpa/n8n-nodes-avalanche",
  "version": "1.0.0",
  "description": "n8n community node for Avalanche blockchain operations",
  "license": "bsl-catalog",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "avalanche",
    "blockchain",
    "crypto"
  ],
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.1.4",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "n8n-workflow": "*",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/AvalancheApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Avalanche/Avalanche.node.js"
    ]
  }
}